# ---- Local dev (single command: npm run dev) ----
# Point /api to your deployed Vercel app so contact/career forms work.
# Set to your Vercel URL (no trailing slash), e.g. https://your-app.vercel.app
VITE_DEV_API=https://your-app.vercel.app

# ---- GoDaddy etc.: set at build time so forms hit your Vercel API ----
# VITE_API_URL=https://your-app.vercel.app

# ---- Backend (Vercel env vars for /api/send-contact, /api/send-career) ----
# Option A (same as your working Nexus app):
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# Option B (alternative names):
# MAIL_USER=your-email@gmail.com
# MAIL_PASS=your-app-password

# Where to receive emails
MAIL_TO=Info@nakitgroup.com
# MAIL_TO_CONTACT=Info@nakitgroup.com
# MAIL_TO_CAREER=Info@nakitgroup.com
